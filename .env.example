# ─── 服务器配置 ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
APP_ENV=development

# ─── 数据库 ──────────────────────────────────────────────────
# 格式: postgres://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgres://hidden:hidden_secret@localhost:5432/hidden

# ─── Redis ──────────────────────────────────────────────────
# 格式（无密码）: redis://127.0.0.1:6379
# 格式（有密码）: redis://:密码@127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# ─── 115 账号（必填）─────────────────────────────────────────
# 从浏览器开发者工具 → Network → 任意请求 Headers → Cookie 获取
ACCOUNT_115_COOKIE=UID=xxx; CID=xxx; SEID=xxx

# 115 云盘根目录文件夹 ID（目标存放位置）
ACCOUNT_115_ROOT_FOLDER_ID=0

# 115 转存临时文件夹 ID（转存后再整理移动）
ACCOUNT_115_TEMP_FOLDER_ID=0

# 请求间隔（毫秒），建议 1500~3000，防止触发风控
ACCOUNT_115_REQUEST_INTERVAL_MS=1500

# 请求失败重试次数
ACCOUNT_115_RETRY_TIMES=3

# ─── TMDB ────────────────────────────────────────────────────
# 从 https://www.themoviedb.org/settings/api 获取
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_LANGUAGE=zh-CN

# ─── JWT 认证 ────────────────────────────────────────────────
# 请使用高强度随机字符串（生产环境必须修改！）
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRATION_HOURS=24

# ─── 转存限制 ────────────────────────────────────────────────
# 单次转存最大文件总大小（GB）
TRANSFER_MAX_SIZE_GB=80

# 单次转存最多文件数量
TRANSFER_MAX_FILE_COUNT=200

# 要求账号至少剩余空间（GB），低于此值拒绝转存
TRANSFER_MIN_FREE_SPACE_GB=20

# ─── 分享创建限速（风控规避）────────────────────────────────────
# 每分钟最多创建分享链接数
SHARE_MAX_CREATE_PER_MINUTE=2

# 每小时最多创建分享链接数
SHARE_MAX_CREATE_PER_HOUR=60

# 每天最多创建分享链接数
SHARE_MAX_CREATE_PER_DAY=300

# 相邻两次创建分享的最小间隔（秒）
SHARE_MIN_INTERVAL_SECS=30

# 间隔的随机抖动范围（秒）
SHARE_RANDOM_JITTER_SECS=10

# ─── 清理规则 ────────────────────────────────────────────────
# 过滤小于此大小的视频文件（MB），防止垃圾文件入库
CLEAN_MIN_VIDEO_SIZE_MB=100

# ─── Docker Compose 专用变量 ─────────────────────────────────
POSTGRES_PASSWORD=hidden_secret
REDIS_PASSWORD=
APP_PORT=8080
